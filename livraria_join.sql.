SELECT 
    livros.titulo AS 'Título do Livro',
    livros.preco AS 'Preço',
    autores.nome_autor AS 'Autor',
    autores.nacionalidade AS 'Nacionalidade'
FROM livros
INNER JOIN autores ON livros.id_autor = autores.id_autor;
